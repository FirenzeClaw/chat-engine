# Chat Engine 配置 — QQ Bot + LLM 一体

# === QQ Bot（必填）===
QQ_BOT_APPID=your_app_id
QQ_BOT_SECRET=your_app_secret
QQ_WS_URL=wss://api.sgroup.qq.com/websocket

# === LLM API（必填）===
# 支持任何 OpenAI 兼容 API：DeepSeek / Ollama / vLLM / 硅基流动
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com

# 辅脑：快速、便宜，用于即时回复（<500ms 目标）
LLM_FAST_MODEL=deepseek-chat
# 主脑：强推理，用于评估/追答生成
LLM_STRONG_MODEL=deepseek-chat

# === 服务器 ===
HTTP_HOST=0.0.0.0
HTTP_PORT=18090

# === 记忆 ===
DB_PATH=botuser/memory.db

# === 会话 ===
SESSION_TTL=3600
MAX_CONTEXT_ROUNDS=20
MAX_CONTEXT_TOKENS=4096
CONTEXT_SATURATION_PCT=0.80
MEMORY_INJECT_MODE=auto
ACCESS_BOOST_DAYS=7
ACCESS_BOOST_MIN=3

# === 追答 ===
FOLLOW_UP_ENABLED=true
FOLLOW_UP_MAX_PER_HOUR=5

# === Phase 1: 记忆引擎 ===
# 模糊层(gist)过期天数
DECAY_GIST_DAYS=90
# 精确层(detail)半衰天数
DECAY_DETAIL_DAYS=30
# 精确层自动模糊化天数
AUTO_MIGRATE_DAYS=60
# 检索候选上限
MAX_RETRIEVAL_CANDIDATES=20
# 检索最终返回数量
MAX_RETRIEVAL_RESULTS=5
# 深刻记忆集群: 触发窗口(天)
CLUSTER_TRIGGER_DAYS=14
# 深刻记忆集群: 最少访问次数
CLUSTER_TRIGGER_MIN_ACCESS=3

# === System Prompt ===
DEFAULT_SYSTEM_PROMPT=你是一个友好的聊天助手。回复自然简洁，2-4 句话为宜。可以适度使用表情符号，但不要过度。
